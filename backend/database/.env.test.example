# Test Database Configuration
# Copy this file to .env.test and update with your test database credentials

# PostgreSQL Test Database
TEST_DB_HOST=localhost
TEST_DB_PORT=5432
TEST_DB_NAME=sai_mahendra_test
TEST_DB_USER=postgres
TEST_DB_PASSWORD=postgres

# MongoDB Test Database
TEST_MONGO_URL=mongodb://localhost:27017

# Redis Test Database
TEST_REDIS_HOST=localhost
TEST_REDIS_PORT=6379

# Note: Tests use separate databases/instances to avoid affecting development data
# - PostgreSQL: Uses 'sai_mahendra_test' database
# - MongoDB: Uses 'sai_mahendra_test' database
# - Redis: Uses DB 15 (separate from default DB 0)
