    "dotenv": "^16.3.1",
    "winston": "^3.10.0",
    "redis": "^4.6.7",
    "pg": "^8.11.1",
    "uuid": "^9.0.0",
    "web-push": "^3.6.6",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/cors": "^2.8.13",
    "@types/compression": "^1.7.2",
    "@types/node": "^20.4.2",
    "@types/pg": "^8.10.2",
    "@types/uuid": "^9.0.2",
    "@types/web-push": "^3.6.3",
    "@types/jsonwebtoken": "^9.0.2",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.44.0",
    "jest": "^29.6.1",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.6"
