{
  "name": "@sai-mahendra/backend",
  "version": "1.0.0",
  "description": "Sai Mahendra Platform Backend Services",
  "private": true,
  "workspaces": [
    "services/*",
    "shared/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:gateway\" \"npm run dev:auth\" \"npm run dev:course\" \"npm run dev:payment\" \"npm run dev:contact\" \"npm run dev:content\" \"npm run dev:analytics\" \"npm run dev:notification\"",
    "dev:gateway": "cd services/api-gateway && npm run dev",
    "dev:auth": "cd services/user-management && npm run dev",
    "dev:course": "cd services/course-management && npm run dev",
    "dev:payment": "cd services/payment && npm run dev",
    "dev:contact": "cd services/contact && npm run dev",
    "dev:content": "cd services/content-management && npm run dev",
    "dev:analytics": "cd services/analytics && npm run dev",
    "dev:notification": "cd services/notification && npm run dev",
    "start:services": "node start-services.js",
    "test:integration": "node integration-test.js",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "docker:build": "docker-compose -f docker-compose.dev.yml build",
    "docker:up": "docker-compose -f docker-compose.dev.yml up -d",
    "docker:down": "docker-compose -f docker-compose.dev.yml down"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.54.0",
    "nodemon": "^3.0.2",
    "typescript": "^5.3.0",
    "axios": "^1.6.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}