{
  "dashboard": {
    "title": "Conversion Funnel & Monitoring",
    "tags": ["business", "conversion", "funnel", "sai-mahendra"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 1,
    "refresh": "1m",
    "time": {
      "from": "now-24h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Conversion Funnel Overview",
        "type": "row",
        "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
        "collapsed": false
      },
      {
        "id": 2,
        "title": "Conversion Funnel (Last Hour)",
        "type": "graph",
        "gridPos": {"h": 10, "w": 24, "x": 0, "y": 1},
        "targets": [
          {
            "expr": "business:funnel_visitors:1h",
            "legendFormat": "1. Visitors",
            "refId": "A"
          },
          {
            "expr": "business:funnel_signups:1h",
            "legendFormat": "2. Signups",
            "refId": "B"
          },
          {
            "expr": "business:funnel_enrollment_starts:1h",
            "legendFormat": "3. Enrollment Starts",
            "refId": "C"
          },
          {
            "expr": "business:funnel_payment_initiated:1h",
            "legendFormat": "4. Payment Initiated",
            "refId": "D"
          },
          {
            "expr": "business:funnel_payment_completed:1h",
            "legendFormat": "5. Payment Completed",
            "refId": "E"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Count", "logBase": 1},
          {"format": "short"}
        ],
        "xaxis": {
          "mode": "time"
        },
        "lines": true,
        "fill": 2,
        "linewidth": 2,
        "steppedLine": false,
        "legend": {
          "show": true,
          "alignAsTable": true,
          "avg": false,
          "current": true,
          "max": false,
          "min": false,
          "rightSide": false,
          "total": true,
          "values": true
        },
        "tooltip": {
          "shared": true,
          "sort": 2,
          "value_type": "individual"
        }
      },
      {
        "id": 3,
        "title": "Funnel Visualization",
        "type": "stat",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 11},
        "targets": [
          {
            "expr": "business:funnel_visitors:1h",
            "refId": "A"
          },
          {
            "expr": "business:funnel_signups:1h",
            "refId": "B"
          },
          {
            "expr": "business:funnel_enrollment_starts:1h",
            "refId": "C"
          },
          {
            "expr": "business:funnel_payment_initiated:1h",
            "refId": "D"
          },
          {
            "expr": "business:funnel_payment_completed:1h",
            "refId": "E"
          }
        ],
        "options": {
          "graphMode": "none",
          "colorMode": "background",
          "orientation": "horizontal",
          "textMode": "value_and_name"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "decimals": 0
          },
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "A"},
              "properties": [
                {"id": "displayName", "value": "1. Visitors"},
                {"id": "color", "value": {"mode": "fixed", "fixedColor": "blue"}}
              ]
            },
            {
              "matcher": {"id": "byName", "options": "B"},
              "properties": [
                {"id": "displayName", "value": "2. Signups"},
                {"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}
              ]
            },
            {
              "matcher": {"id": "byName", "options": "C"},
              "properties": [
                {"id": "displayName", "value": "3. Enrollment Starts"},
                {"id": "color", "value": {"mode": "fixed", "fixedColor": "yellow"}}
              ]
            },
            {
              "matcher": {"id": "byName", "options": "D"},
              "properties": [
                {"id": "displayName", "value": "4. Payment Initiated"},
                {"id": "color", "value": {"mode": "fixed", "fixedColor": "orange"}}
              ]
            },
            {
              "matcher": {"id": "byName", "options": "E"},
              "properties": [
                {"id": "displayName", "value": "5. Payment Completed"},
                {"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}
              ]
            }
          ]
        }
      },
      {
        "id": 4,
        "title": "Conversion Rates",
        "type": "row",
        "gridPos": {"h": 1, "w": 24, "x": 0, "y": 19},
        "collapsed": false
      },
      {
        "id": 5,
        "title": "Visitor → Signup",
        "type": "gauge",
        "gridPos": {"h": 6, "w": 6, "x": 0, "y": 20},
        "targets": [
          {
            "expr": "business:conversion_visitor_to_signup:1h",
            "refId": "A"
          }
        ],
        "options": {
          "showThresholdLabels": true,
          "showThresholdMarkers": true
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 2, "color": "yellow"},
                {"value": 5, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 6,
        "title": "Signup → Enrollment",
        "type": "gauge",
        "gridPos": {"h": 6, "w": 6, "x": 6, "y": 20},
        "targets": [
          {
            "expr": "business:conversion_signup_to_enrollment:1h",
            "refId": "A"
          }
        ],
        "options": {
          "showThresholdLabels": true,
          "showThresholdMarkers": true
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 30, "color": "yellow"},
                {"value": 50, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 7,
        "title": "Enrollment → Payment",
        "type": "gauge",
        "gridPos": {"h": 6, "w": 6, "x": 12, "y": 20},
        "targets": [
          {
            "expr": "business:conversion_enrollment_to_payment:1h",
            "refId": "A"
          }
        ],
        "options": {
          "showThresholdLabels": true,
          "showThresholdMarkers": true
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 60, "color": "yellow"},
                {"value": 80, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 8,
        "title": "Payment Success",
        "type": "gauge",
        "gridPos": {"h": 6, "w": 6, "x": 18, "y": 20},
        "targets": [
          {
            "expr": "business:conversion_payment_success:1h",
            "refId": "A"
          }
        ],
        "options": {
          "showThresholdLabels": true,
          "showThresholdMarkers": true
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 90, "color": "yellow"},
                {"value": 95, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 9,
        "title": "Overall Conversion Rate",
        "type": "stat",
        "gridPos": {"h": 4, "w": 24, "x": 0, "y": 26},
        "targets": [
          {
            "expr": "business:conversion_overall:1h",
            "refId": "A"
          }
        ],
        "options": {
          "graphMode": "area",
          "colorMode": "value",
          "textMode": "value_and_name"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "decimals": 2,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 1, "color": "yellow"},
                {"value": 3, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 10,
        "title": "Conversion Trends",
        "type": "row",
        "gridPos": {"h": 1, "w": 24, "x": 0, "y": 30},
        "collapsed": false
      },
      {
        "id": 11,
        "title": "Conversion Rates Over Time",
        "type": "graph",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 31},
        "targets": [
          {
            "expr": "business:conversion_visitor_to_signup:1h",
            "legendFormat": "Visitor → Signup",
            "refId": "A"
          },
          {
            "expr": "business:conversion_signup_to_enrollment:1h",
            "legendFormat": "Signup → Enrollment",
            "refId": "B"
          },
          {
            "expr": "business:conversion_enrollment_to_payment:1h",
            "legendFormat": "Enrollment → Payment",
            "refId": "C"
          },
          {
            "expr": "business:conversion_payment_success:1h",
            "legendFormat": "Payment Success",
            "refId": "D"
          },
          {
            "expr": "business:conversion_overall:1h",
            "legendFormat": "Overall Conversion",
            "refId": "E"
          }
        ],
        "yaxes": [
          {"format": "percent", "label": "Conversion Rate", "min": 0},
          {"format": "short"}
        ],
        "xaxis": {
          "mode": "time"
        },
        "lines": true,
        "fill": 1,
        "linewidth": 2,
        "legend": {
          "show": true,
          "alignAsTable": true,
          "avg": true,
          "current": true,
          "max": true,
          "min": true,
          "rightSide": false
        }
      },
      {
        "id": 12,
        "title": "Drop-off Analysis",
        "type": "row",
        "gridPos": {"h": 1, "w": 24, "x": 0, "y": 39},
        "collapsed": false
      },
      {
        "id": 13,
        "title": "Funnel Drop-off Rates",
        "type": "bargauge",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 40},
        "targets": [
          {
            "expr": "100 - business:conversion_visitor_to_signup:1h",
            "legendFormat": "Visitor Drop-off",
            "refId": "A"
          },
          {
            "expr": "100 - business:conversion_signup_to_enrollment:1h",
            "legendFormat": "Signup Drop-off",
            "refId": "B"
          },
          {
            "expr": "100 - business:conversion_enrollment_to_payment:1h",
            "legendFormat": "Enrollment Drop-off",
            "refId": "C"
          },
          {
            "expr": "100 - business:conversion_payment_success:1h",
            "legendFormat": "Payment Drop-off",
            "refId": "D"
          }
        ],
        "options": {
          "orientation": "horizontal",
          "displayMode": "gradient",
          "showUnfilled": true
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "color": {"mode": "continuous-RdYlGr"},
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 50, "color": "yellow"},
                {"value": 80, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 14,
        "title": "Conversion Funnel Table",
        "type": "table",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 40},
        "targets": [
          {
            "expr": "business:funnel_visitors:1h",
            "format": "table",
            "instant": true,
            "refId": "A"
          },
          {
            "expr": "business:funnel_signups:1h",
            "format": "table",
            "instant": true,
            "refId": "B"
          },
          {
            "expr": "business:funnel_enrollment_starts:1h",
            "format": "table",
            "instant": true,
            "refId": "C"
          },
          {
            "expr": "business:funnel_payment_initiated:1h",
            "format": "table",
            "instant": true,
            "refId": "D"
          },
          {
            "expr": "business:funnel_payment_completed:1h",
            "format": "table",
            "instant": true,
            "refId": "E"
          },
          {
            "expr": "business:conversion_visitor_to_signup:1h",
            "format": "table",
            "instant": true,
            "refId": "F"
          },
          {
            "expr": "business:conversion_signup_to_enrollment:1h",
            "format": "table",
            "instant": true,
            "refId": "G"
          },
          {
            "expr": "business:conversion_enrollment_to_payment:1h",
            "format": "table",
            "instant": true,
            "refId": "H"
          },
          {
            "expr": "business:conversion_payment_success:1h",
            "format": "table",
            "instant": true,
            "refId": "I"
          }
        ],
        "transformations": [
          {
            "id": "seriesToColumns",
            "options": {
              "byField": "Time"
            }
          },
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true
              },
              "indexByName": {},
              "renameByName": {
                "Value #A": "Visitors",
                "Value #B": "Signups",
                "Value #C": "Enrollment Starts",
                "Value #D": "Payment Initiated",
                "Value #E": "Payment Completed",
                "Value #F": "Visitor→Signup (%)",
                "Value #G": "Signup→Enrollment (%)",
                "Value #H": "Enrollment→Payment (%)",
                "Value #I": "Payment Success (%)"
              }
            }
          }
        ],
        "fieldConfig": {
          "overrides": [
            {
              "matcher": {"id": "byRegexp", "options": ".*%.*"},
              "properties": [
                {"id": "unit", "value": "percent"},
                {"id": "decimals", "value": 2},
                {
                  "id": "custom.cellOptions",
                  "value": {
                    "type": "color-background",
                    "mode": "gradient"
                  }
                }
              ]
            }
          ]
        }
      },
      {
        "id": 15,
        "title": "Alerts & Monitoring",
        "type": "row",
        "gridPos": {"h": 1, "w": 24, "x": 0, "y": 48},
        "collapsed": false
      },
      {
        "id": 16,
        "title": "Active Conversion Alerts",
        "type": "alertlist",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 49},
        "options": {
          "showOptions": "current",
          "maxItems": 20,
          "sortOrder": 1,
          "dashboardAlerts": false,
          "alertName": "",
          "dashboardTitle": "",
          "tags": ["business", "conversion"],
          "stateFilter": {
            "firing": true,
            "pending": true,
            "noData": false,
            "normal": false,
            "error": true
          },
          "folderId": null,
          "nameFilter": "",
          "alertInstanceLabelFilter": ""
        }
      }
    ]
  }
}
