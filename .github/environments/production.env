# Production Environment Configuration
ENVIRONMENT=production
AWS_REGION=us-east-1
EKS_CLUSTER_NAME=sai-mahendra-prod
NAMESPACE=production

# Database Configuration
DATABASE_HOST=sai-mahendra-prod.cluster-xxxxx.us-east-1.rds.amazonaws.com
DATABASE_PORT=5432
DATABASE_NAME=sai_mahendra_prod
REDIS_HOST=sai-mahendra-prod.xxxxx.cache.amazonaws.com
REDIS_PORT=6379
MONGODB_HOST=sai-mahendra-prod.xxxxx.docdb.amazonaws.com
MONGODB_PORT=27017

# API Configuration
API_GATEWAY_URL=https://api.saimahendra.com
CORS_ORIGINS=https://saimahendra.com,https://www.saimahendra.com,https://admin.saimahendra.com

# External Services
RAZORPAY_MODE=live
STRIPE_MODE=live
SENDGRID_MODE=production
WHATSAPP_MODE=production

# Monitoring
LOG_LEVEL=warn
ENABLE_DEBUG=false
METRICS_ENABLED=true

# Resource Limits
MIN_REPLICAS=3
MAX_REPLICAS=10
CPU_REQUEST=500m
CPU_LIMIT=2000m
MEMORY_REQUEST=512Mi
MEMORY_LIMIT=2Gi

# Feature Flags
ENABLE_RATE_LIMITING=true
ENABLE_CACHING=true
ENABLE_ANALYTICS=true
ENABLE_BLUE_GREEN=true
ENABLE_CANARY=true

# High Availability
ENABLE_MULTI_AZ=true
ENABLE_AUTO_SCALING=true
ENABLE_CIRCUIT_BREAKER=true
