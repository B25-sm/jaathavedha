# Staging Environment Configuration
ENVIRONMENT=staging
AWS_REGION=us-east-1
EKS_CLUSTER_NAME=sai-mahendra-staging
NAMESPACE=staging

# Database Configuration
DATABASE_HOST=sai-mahendra-staging.cluster-xxxxx.us-east-1.rds.amazonaws.com
DATABASE_PORT=5432
DATABASE_NAME=sai_mahendra_staging
REDIS_HOST=sai-mahendra-staging.xxxxx.cache.amazonaws.com
REDIS_PORT=6379
MONGODB_HOST=sai-mahendra-staging.xxxxx.docdb.amazonaws.com
MONGODB_PORT=27017

# API Configuration
API_GATEWAY_URL=https://staging.saimahendra.com
CORS_ORIGINS=https://staging.saimahendra.com,https://staging-admin.saimahendra.com

# External Services
RAZORPAY_MODE=test
STRIPE_MODE=test
SENDGRID_MODE=production
WHATSAPP_MODE=test

# Monitoring
LOG_LEVEL=info
ENABLE_DEBUG=false
METRICS_ENABLED=true

# Resource Limits
MIN_REPLICAS=2
MAX_REPLICAS=5
CPU_REQUEST=250m
CPU_LIMIT=1000m
MEMORY_REQUEST=256Mi
MEMORY_LIMIT=1Gi

# Feature Flags
ENABLE_RATE_LIMITING=true
ENABLE_CACHING=true
ENABLE_ANALYTICS=true
ENABLE_BLUE_GREEN=true
