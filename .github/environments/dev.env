# Development Environment Configuration
ENVIRONMENT=dev
AWS_REGION=us-east-1
EKS_CLUSTER_NAME=sai-mahendra-dev
NAMESPACE=dev

# Database Configuration
DATABASE_HOST=sai-mahendra-dev.cluster-xxxxx.us-east-1.rds.amazonaws.com
DATABASE_PORT=5432
DATABASE_NAME=sai_mahendra_dev
REDIS_HOST=sai-mahendra-dev.xxxxx.cache.amazonaws.com
REDIS_PORT=6379
MONGODB_HOST=sai-mahendra-dev.xxxxx.docdb.amazonaws.com
MONGODB_PORT=27017

# API Configuration
API_GATEWAY_URL=https://dev.saimahendra.com
CORS_ORIGINS=http://localhost:3000,https://dev.saimahendra.com

# External Services
RAZORPAY_MODE=test
STRIPE_MODE=test
SENDGRID_MODE=sandbox
WHATSAPP_MODE=test

# Monitoring
LOG_LEVEL=debug
ENABLE_DEBUG=true
METRICS_ENABLED=true

# Resource Limits
MIN_REPLICAS=1
MAX_REPLICAS=3
CPU_REQUEST=100m
CPU_LIMIT=500m
MEMORY_REQUEST=128Mi
MEMORY_LIMIT=512Mi

# Feature Flags
ENABLE_RATE_LIMITING=true
ENABLE_CACHING=true
ENABLE_ANALYTICS=true
